    "@nestjs/swagger": "^7.0.0",
    "@only3d/database": "workspace:*",
    "@only3d/logger": "workspace:*",
    "adm-zip": "^0.5.17",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fast-xml-parser": "^5.9.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8",
    "@only3d/eslint-config": "workspace:*",
    "@only3d/typescript-config": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
